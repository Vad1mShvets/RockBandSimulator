  m_Script: {fileID: 11500000, guid: 9b0de1441a190476f84d46203267d169, type: 3}
  m_Name: ArtemQuestDialogue1
  m_EditorClassIdentifier:
  Lines:
  - "Oh, hey. So you\u2019re the guy Evgen was talking about?"
  - "Yeah\u2026 times are rough. I could get cigarettes \u2014 just not right now."
  - "But help me out, and I\u2019ll sort you out, no problem."
  - "See that idiot in the beanie? It\u2019s 30 degrees out, by the way. Been messing
    with me for a while now."
  - "I\u2019d deal with him myself \u2014 I usually do \u2014 but I\u2019ve got
    better things to handle. You take care of it, and the cigarettes are yours."
